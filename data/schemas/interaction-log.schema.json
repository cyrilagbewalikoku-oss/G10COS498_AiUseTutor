{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Interaction Log",
  "description": "Log of a learner interaction with SAGE",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "userId": { "type": "string", "description": "Reference to user profile ID" },
    "sessionId": { "type": "string", "description": "Groups interactions within a session" },
    "timestamp": { "type": "string", "format": "date-time" },
    "skillUsed": { "type": "string", "description": "Primary skill active during this interaction" },
    "practiceType": {
      "type": "string",
      "enum": ["prompt_crafting", "output_evaluation", "appropriateness_judgment", "workflow_design", null],
      "description": "Type of practice session (null if not a practice session)"
    },
    "scenarioId": { "type": "string", "description": "Scenario ID if a simulation was running" },
    "turns": {
      "type": "array",
      "description": "Sequence of conversation turns",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string", "enum": ["sage", "learner", "simulated_agent"] },
          "content": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "metadata": {
            "type": "object",
            "description": "Optional metadata like skill transitions, scoring events",
            "properties": {
              "skillTransition": { "type": "string" },
              "scoreEvent": { "type": "object" },
              "simulationMode": { "type": "string", "enum": ["helpful_agent", "flawed_agent", "lab_mode"] },
              "scaffoldingStep": { "type": "string", "enum": ["acknowledge", "nudge", "explain", null], "description": "Which step of the ACKNOWLEDGE→NUDGE→EXPLAIN pattern this turn represents" }
            }
          }
        },
        "required": ["role", "content", "timestamp"]
      }
    },
    "scaffoldingSteps": {
      "type": "array",
      "description": "Tracking of ACKNOWLEDGE → NUDGE → EXPLAIN steps during feedback",
      "items": {
        "type": "object",
        "properties": {
          "turnIndex": { "type": "integer", "description": "Index of the turn where scaffolding occurred" },
          "step": { "type": "string", "enum": ["acknowledge", "nudge", "explain"] },
          "content": { "type": "string" },
          "learnerRespondedToNudge": { "type": "boolean" }
        }
      }
    },
    "closingReflection": {
      "type": "object",
      "description": "The closing reflection question and response",
      "properties": {
        "questionAsked": { "type": "string" },
        "responseGiven": { "type": "string" },
        "skipped": { "type": "boolean" }
      }
    },
    "outcome": {
      "type": "object",
      "properties": {
        "completed": { "type": "boolean", "description": "Whether the interaction reached its intended end" },
        "objectiveMet": { "type": "boolean", "description": "Whether the learning objective was achieved" },
        "notes": { "type": "string" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "turnCount": { "type": "integer" },
        "durationSeconds": { "type": "integer" },
        "promptQualityScore": { "type": "number", "minimum": 0, "maximum": 5 },
        "verificationAttempted": { "type": "boolean", "description": "Did the user try to verify AI output?" },
        "nudgeResponseQuality": { "type": "number", "minimum": 0, "maximum": 5, "description": "How thoughtfully the learner responded to scaffolding nudges" }
      }
    },
    "contextSourcesUsed": {
      "type": "array",
      "description": "Which CollaborAITE data sources were referenced during this interaction",
      "items": { "type": "string", "enum": ["class_slides", "channel_conversations", "user_profile", "prior_assignments", "anonymized_transcripts"] }
    }
  },
  "required": ["id", "userId", "sessionId", "timestamp", "skillUsed", "turns"]
}